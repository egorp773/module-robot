# Preferred template for devices that expose ID_SERIAL_SHORT. Do not copy this
# file directly while TODO values remain. Discover the actual identity with
# robot_pi/scripts/setup_udev.sh and let that script safely render the installed
# rule. If ID_SERIAL_SHORT is absent, the script instead generates an ID_PATH
# rule which binds the ESP32 to a physical Pi port or full hub-port topology.
SUBSYSTEM=="tty", ATTRS{idVendor}=="TODO_USB_VENDOR_ID", ATTRS{idProduct}=="TODO_USB_PRODUCT_ID", ENV{ID_SERIAL_SHORT}=="TODO_USB_SERIAL", SYMLINK+="module-esp32", GROUP="dialout", MODE="0660", TAG+="systemd"
